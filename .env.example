# .env.example — skeleton per la configurazione di doorphoneserver
# Copia questo file in .env e compila i valori reali:
#   cp .env.example .env
#
# Il file .env NON deve essere versionato (è in .gitignore).
# Questo skeleton (.env.example) è versionato come riferimento.

# --- Mumble ---
# Username e password del client Mumble (devono corrispondere al server locale)
MUMBLE_USERNAME=Doorpi
MUMBLE_PASSWORD=

# --- Camera IP (Reolink) ---
# Credenziali di accesso alla camera IP
CAMERA_USERNAME=
CAMERA_PASSWORD=

# --- Pushover (notifiche push) ---
# Ottenibili da https://pushover.net/
PUSHOVER_API_TOKEN=
PUSHOVER_USER_KEY=

# --- OpenRouter AI ---
# API key per le funzionalità AI (ottenibile da https://openrouter.ai/)
OPENROUTER_API_KEY=
