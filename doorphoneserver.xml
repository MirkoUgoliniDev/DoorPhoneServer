<?xml version="1.0" encoding="UTF-8"?>

<document type="doorphoneserver/xml">

	<accounts>
		<account name="doorphoneserver-community" default="true">
			<serverandport>192.168.1.151:64738</serverandport>
			<insecure>true</insecure>
			<register>false</register>
			<certificate>/home/doorphoneserver/mumble.pem</certificate>
			<channel/>
			<ident>DoorPi</ident>
		</account>
	</accounts>


	<global>

		<software>

			<settings>
				<singleinstance>true</singleinstance>
				<outputdevice>Speaker</outputdevice>
				<outputvolcontroldevice>Speaker</outputvolcontroldevice>
				<outputmutecontroldevice>Speaker</outputmutecontroldevice>
				<logfilenameandpath>/home/doorphoneserver/doorphoneserver.log</logfilenameandpath>
				<logging>fileonly</logging>
				<loglevel>info</loglevel>
				<logmaxsizemb>5</logmaxsizemb>
				<logretentiondays>7</logretentiondays>
				<streamonstart>false</streamonstart>
				<streamafterstart>5</streamafterstart>
				<streamsendmessage>false</streamsendmessage>
				<txonstart>false</txonstart>
				<txafterstart>5</txafterstart>
				<simplexwithmute>true</simplexwithmute>
				<voiceactivitytimermsecs>200</voiceactivitytimermsecs>
			</settings>

			<tts enabled="true">
				<volumelevel>80</volumelevel>
				<language>en</language>
				<sound action="message" file="" enabled="false"/>
				<sound action="ring" file="soundfiles/events/door_ring.wav" blocking="false" enabled="true"/>
				<sound action="unlookdoor" file="soundfiles/events/unlock.mp3" blocking="false" enabled="true"/>
			</tts>

			<pushover enabled="true" log="false"></pushover>


       <camera debug="false">
        <video enabled="true">
          <endpoint>rtsp://192.168.1.124:554/Preview_01_sub</endpoint>
        </video>
        <snapshot enabled="true">
         <method>ffmpeg</method>
         <endpoint>http://192.168.1.124/cgi-bin/api.cgi?cmd=Snap&amp;channel=0&amp;rs=abc</endpoint>
         <maxsnapshots>100</maxsnapshots>
         <retentiondays>30</retentiondays>
         <dir>/home/doorphoneserver/snapshots</dir>
        </snapshot>
       </camera>


			<remotecontrol>
			  
				<http listenport="8080" enabled="true">
					<command action="mute" funcparamname="mute" message="Mute" enabled="true"/>
					<command action="unmute" funcparamname="unmute" message="Unute" enabled="true"/>
					<command action="listapi" funcparamname="" message="List API" enabled="true"/>
					<command action="unlockdoor" funcparamname="P" message="unlockdoor" enabled="true"/>
					<command action="powertablet_on" funcparamname="" message="powertablet_on" enabled="true"/>
					<command action="powertablet_off" funcparamname="" message="powertablet_off" enabled="true"/>
					<command action="sendpushovermessage" funcparamname="" message="sendpushovermessage" enabled="true"/>
					<command action="takesnapshot" funcparamname="" message="takesnapshot" enabled="true"/>
					<command action="reboot_server" funcparamname="" message="reboot_server" enabled="true"/>
				</http>

				<mqtt enabled="false">
					<settings>
            <mqtttopic>thailand/bangkok/company/doorphoneserver</mqtttopic>
            <mqttbroker>tcp://yourserver.com:1883</mqttbroker>
            <mqttpassword/>
            <mqttuser/>
            <mqttid>doorphoneserver002</mqttid>
            <qos>0</qos>
          </settings>
					<commands>
           <command action="attention" message="Attention LED" enabled="true"/>
           <command action="relay" message="Relay Control" enabled="true"/>
					</commands>
				</mqtt>

			</remotecontrol>


		<tablet enabled="true">
    <p1 kioskmode="true" hide_status_bar="true" miclevel="100" speakerlevel="100" screenbrightnesslevel="100"></p1>
    <p2 kioskmode="true" hide_status_bar="true"  miclevel="100" speakerlevel="100" screenbrightnesslevel="100"></p2>
    <p3 kioskmode="true" hide_status_bar="true" miclevel="100" speakerlevel="100" screenbrightnesslevel="100"></p3>
    <p4 kioskmode="true" hide_status_bar="true" miclevel="140" speakerlevel="50" screenbrightnesslevel="100"></p4>
    </tablet>

		</software>


		<hardware>

			<io backend="esp32">
			  
				<pulse leadingmsecs="1000" pulsemsecs="1000" trailingmsecs="1000"/>

  			<pins enabled="true">
         <input>
          <pin name="p1"     pinno="22" enabled="true"  log="false" desc="Pulsante P1"/>
          <pin name="p2"     pinno="27" enabled="true"  log="false" desc="Pulsante P2"/>
          <pin name="p3"     pinno="17" enabled="true"  log="false" desc="Pulsante P3"/>
         </input>
         <output>
          <pin name="unlockdoor"   pinno="5"  enabled="true"  log="false" desc="Unlock Main Door"/>
          <pin name="power_tablet" pinno="19" enabled="true"  log="false" desc="Power Tablet"/>
         </output>
        </pins>

			</io>

		</hardware>

	</global>

</document>
